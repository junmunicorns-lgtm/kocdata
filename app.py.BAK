# ============================================================
# 页面4：趋势分析
# ============================================================
elif page == "📈 趋势分析":
    st.title("📈 趋势分析")

    all_data = load_all_data()
    if all_data.empty:
        st.warning("暂无数据")
        st.stop()

    unique_dates = sorted(all_data['数据日期'].unique())

    if len(unique_dates) < 2:
        st.info("💡 趋势分析需要至少2天的数据。目前只有1天，请上传更多日期的CSV文件。")

        # 仍可以显示当天的汇总
        st.subheader(f"📅 {unique_dates[0]} 数据汇总")
        df = all_data[all_data['数据日期'] == unique_dates[0]]

        summary_metrics = ['粉丝数', '涨粉', '人气峰值', '视频播放量', '视频点赞量',
                           '视频评论量', '作品数', 'feed_acu', '开播有效时长_分钟']
        available_metrics = [c for c in summary_metrics if c in df.columns]

        summary = {}
        for m in available_metrics:
            summary[m] = {
                '总和': df[m].sum(),
                '平均值': df[m].mean(),
                '中位数': df[m].median(),
                '最大值': df[m].max(),
                '最小值': df[m].min()
            }
        summary_df = pd.DataFrame(summary).T
        st.dataframe(summary_df, use_container_width=True)
        st.stop()

    # 汇总方式
    agg_col1, agg_col2 = st.columns([1, 3])
    with agg_col1:
        agg_method = st.radio("汇总粒度", ["日", "周", "月"])

    # 筛选条件
    with st.expander("🔍 筛选"):
        f1, f2 = st.columns(2)
        with f1:
            if '运营经纪人' in all_data.columns:
                agents = ['全部'] + sorted(all_data['运营经纪人'].dropna().unique().tolist())
                sel_agent = st.selectbox("运营经纪人", agents, key="trend_agent")
        with f2:
            if '签约类型' in all_data.columns:
                types = ['全部'] + sorted(all_data['签约类型'].dropna().unique().tolist())
                sel_type = st.selectbox("签约类型", types, key="trend_type")

    filtered = all_data.copy()
    if '运营经纪人' in filtered.columns and sel_agent != '全部':
        filtered = filtered[filtered['运营经纪人'] == sel_agent]
    if '签约类型' in filtered.columns and sel_type != '全部':
        filtered = filtered[filtered['签约类型'] == sel_type]

    # 转换日期
    filtered['日期'] = pd.to_datetime(filtered['数据日期'], errors='coerce')
    filtered = filtered.dropna(subset=['日期'])

    if agg_method == "周":
        filtered['周期'] = filtered['日期'].dt.to_period('W').astype(str)
    elif agg_method == "月":
        filtered['周期'] = filtered['日期'].dt.to_period('M').astype(str)
    else:
        filtered['周期'] = filtered['数据日期']

    # 选择指标
    trend_metrics = ['粉丝数', '涨粉', '人气峰值', '视频播放量', '视频点赞量',
                     '视频评论量', '作品数', 'feed_acu', '开播有效时长_分钟', 'feed看播时长_分钟']
    available_metrics = [c for c in trend_metrics if c in filtered.columns]

    selected_metrics = st.multiselect("选择分析指标", available_metrics,
                                       default=available_metrics[:4])

    # 汇总方式
    agg_func = st.radio("汇总方式", ["总和", "平均值", "中位数"], horizontal=True)
    agg_map = {"总和": "sum", "平均值": "mean", "中位数": "median"}

    if selected_metrics:
        grouped = filtered.groupby('周期')[selected_metrics].agg(agg_map[agg_func]).reset_index()
        grouped = grouped.sort_values('周期')

        for metric in selected_metrics:
            fig = px.line(grouped, x='周期', y=metric,
                          title=f"{metric} - {agg_func}（按{agg_method}）",
                          markers=True)
            fig.update_layout(height=350)
            st.plotly_chart(fig, use_container_width=True)

        # 汇总表格
        st.subheader("📊 汇总数据表")
        st.dataframe(grouped, use_container_width=True)

        csv_data = grouped.to_csv(index=False).encode('utf-8-sig')
        st.download_button("📥 导出汇总数据", csv_data,
                            file_name=f"趋势汇总_{agg_method}.csv", mime="text/csv")


# ============================================================
# 页面5：自定义运算
