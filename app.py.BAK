        with filter_col2:
            if '签约类型' in df.columns:
                types = ['全部'] + sorted(df['签约类型'].dropna().unique().tolist())
                sel_type = st.selectbox("签约类型", types)
                if sel_type != '全部':
                    df = df[df['签约类型'] == sel_type]

        with filter_col3:
            if '招募经纪人' in df.columns:
                recruiters = ['全部'] + sorted(df['招募经纪人'].dropna().unique().tolist())
                sel_recruiter = st.selectbox("招募经纪人", recruiters)
                if sel_recruiter != '全部':
                    df = df[df['招募经纪人'] == sel_recruiter]

        with filter_col4:
            # 搜索作者
            search_text = st.text_input("🔎 搜索作者昵称")
