DATA_DIR = Path("data")

# ============================================================
# 工具函数
# ============================================================

@st.cache_data
def parse_duration_to_minutes(text):
    """将 '5小时59分钟53秒' 格式转为总分钟数（浮点）"""
    if pd.isna(text) or str(text).strip() in ('', '-', '0'):
        return 0.0
    text = str(text)
    hours = 0
    minutes = 0
    seconds = 0
    h_match = re.search(r'(\d+)小时', text)
    m_match = re.search(r'(\d+)分钟', text)
    s_match = re.search(r'(\d+)秒', text)
    if h_match:
        hours = int(h_match.group(1))
    if m_match:
        minutes = int(m_match.group(1))
    if s_match:
        seconds = int(s_match.group(1))
    return hours * 60 + minutes + seconds / 60


def parse_duration_col(series):
    """对整列进行时长解析"""
    return series.apply(parse_duration_to_minutes)


def safe_numeric(series):
    """安全转为数值"""
    return pd.to_numeric(series, errors='coerce').fillna(0)


@st.cache_data
def load_single_csv(filepath):
    """加载单个CSV文件"""
    df = pd.read_csv(filepath, dtype={'主播ID': str, '抖音号': str, '抖音号（原）': str,
                                       '火山号': str, '火山号（原）': str, '西瓜号': str})
    return df


def process_dataframe(df, date_label=None):
    """处理DataFrame：解析时长、转换数值"""
    df = df.copy()

    # 添加日期标签
    if date_label:
        df['数据日期'] = date_label

    # 时长列解析
    duration_cols = ['开播总时长', '开播有效时长', 'feed看播时长']
    for col in duration_cols:
        if col in df.columns:
            df[col + '_分钟'] = parse_duration_col(df[col])

    # 数值列转换
    numeric_cols = ['粉丝数', '涨粉', '人气峰值', '作品数', '视频播放量',
                    '视频点赞量', '视频评论量', 'feed_acu', '分成比-直播音浪收益',
                    '视频个播有效天']
    for col in numeric_cols:
        if col in df.columns:
            df[col] = safe_numeric(df[col])

    return df


def get_available_dates():
    """获取 data/ 文件夹下所有CSV文件的日期列表"""
    if not DATA_DIR.exists():
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        return []
    files = sorted(DATA_DIR.glob("*.csv"))
    dates = []
    for f in files:
        # 尝试从文件名提取日期
        name = f.stem  # 去掉.csv
        # 支持格式: 2026-03-10 或 20260310
        try:
            d = datetime.strptime(name, "%Y-%m-%d").date()
            dates.append((d, f))
        except ValueError:
            try:
                d = datetime.strptime(name, "%Y%m%d").date()
                dates.append((d, f))
            except ValueError:
                # 无法解析日期，使用文件名
                dates.append((name, f))
    return dates


@st.cache_data
def load_all_data():
    """加载所有日期的CSV数据"""
    date_files = get_available_dates()
    if not date_files:
        return pd.DataFrame()

    all_dfs = []
    for date_label, filepath in date_files:
        df = load_single_csv(filepath)
        df = process_dataframe(df, date_label=str(date_label))
        all_dfs.append(df)

    if all_dfs:
        return pd.concat(all_dfs, ignore_index=True)
    return pd.DataFrame()


def load_latest_data():
    """加载最新一天的数据"""
    date_files = get_available_dates()
    if not date_files:
        return pd.DataFrame()
    latest_date, latest_file = date_files[-1]
    df = load_single_csv(latest_file)
    df = process_dataframe(df, date_label=str(latest_date))
    return df


