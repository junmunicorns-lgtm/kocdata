elif page == "🔧 自定义运算":
    st.title("🔧 自定义运算")

    df = load_latest_data()
    if df.empty:
        st.warning("暂无数据")
        st.stop()

    st.info("""
    💡 你可以用已有的数值列创建自定义计算指标。

    **可用的数值列（直接用列名）：**
    粉丝数、涨粉、人气峰值、视频播放量、视频点赞量、视频评论量、作品数、feed_acu、
    开播总时长_分钟、开播有效时长_分钟、feed看播时长_分钟、分成比-直播音浪收益、视频个播有效天
    """)

    # 预设公式
    st.subheader("📐 预设公式")
    preset_formulas = {
        "互动率 = (点赞+评论) / 播放量": {
            "name": "互动率",
            "formula": "(视频点赞量 + 视频评论量) / 视频播放量.replace(0, float('nan'))"
        },
        "平均每作品播放量 = 播放量 / 作品数": {
            "name": "平均每作品播放量",
            "formula": "视频播放量 / 作品数.replace(0, float('nan'))"
        },
        "有效开播比 = 有效时长 / 总时长": {
            "name": "有效开播比",
            "formula": "开播有效时长_分钟 / 开播总时长_分钟.replace(0, float('nan'))"
        },
        "每分钟涨粉 = 涨粉 / 有效时长": {
            "name": "每分钟涨粉",
            "formula": "涨粉 / 开播有效时长_分钟.replace(0, float('nan'))"
        },
        "每分钟人气 = 人气峰值 / 有效时长": {
            "name": "每分钟人气",
            "formula": "人气峰值 / 开播有效时长_分钟.replace(0, float('nan'))"
        },
    }

    selected_presets = st.multiselect("选择预设公式", list(preset_formulas.keys()))

    for preset_key in selected_presets:
        preset = preset_formulas[preset_key]
        try:
            # 安全地在DataFrame上下文中计算
            col_name = preset["name"]
            if "互动率" in col_name:
                df[col_name] = (df['视频点赞量'] + df['视频评论量']) / df['视频播放量'].replace(0, float('nan'))
            elif "平均每作品播放量" in col_name:
                df[col_name] = df['视频播放量'] / df['作品数'].replace(0, float('nan'))
            elif "有效开播比" in col_name:
                df[col_name] = df['开播有效时长_分钟'] / df['开播总时长_分钟'].replace(0, float('nan'))
            elif "每分钟涨粉" in col_name:
                df[col_name] = df['涨粉'] / df['开播有效时长_分钟'].replace(0, float('nan'))
            elif "每分钟人气" in col_name:
                df[col_name] = df['人气峰值'] / df['开播有效时长_分钟'].replace(0, float('nan'))
        except Exception as e:
            st.error(f"计算 {preset_key} 时出错：{e}")

    st.markdown("---")

    # 自定义公式
    st.subheader("✏️ 自定义公式")
    st.caption("使用Python/Pandas语法。用 `df['列名']` 引用列。")

    custom_name = st.text_input("新指标名称", placeholder="例如：综合得分")
    custom_formula = st.text_area("计算公式", placeholder="例如：df['涨粉'] * 0.3 + df['人气峰值'] * 0.7",
                                   height=80)

    if custom_name and custom_formula:
        if st.button("▶️ 计算"):
            try:
                df[custom_name] = eval(custom_formula)
                st.success(f"✅ 已计算 '{custom_name}'")
            except Exception as e:
                st.error(f"❌ 公式错误：{e}")

    # 显示结果
    st.markdown("---")
    st.subheader("📊 结果")

    # 获取所有数值列（包括新计算的）
    all_numeric = df.select_dtypes(include=['float64', 'int64']).columns.tolist()
    display_cols = ['主播昵称'] + [c for c in all_numeric if c in df.columns]
    display_cols = [c for c in display_cols if c in df.columns]

    # 排序
    sort_options = [c for c in all_numeric if c in df.columns]
    if sort_options:
        sort_by = st.selectbox("排序字段", sort_options,
                                index=0, key="custom_sort")
        df_result = df[display_cols].sort_values(sort_by, ascending=False)
        st.dataframe(df_result.head(100), use_container_width=True, height=500)

        csv_data = df_result.to_csv(index=False).encode('utf-8-sig')
        st.download_button("📥 导出结果", csv_data,
                            file_name="自定义运算结果.csv", mime="text/csv")


# ============================================================
# 底部
