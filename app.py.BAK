            st.metric("人气峰值", f"{int(author_latest.get('人气峰值', 0)):,}")
        with info_col4:
            st.metric("视频播放量", f"{int(author_latest.get('视频播放量', 0)):,}")

        st.markdown("---")

        # 全部字段信息
