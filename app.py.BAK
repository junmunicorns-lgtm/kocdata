    with chart_col4:
        st.subheader("涨粉 Top 20")
        if '涨粉' in df.columns and '主播昵称' in df.columns:
            top20 = df.nlargest(20, '涨粉')[['主播昵称', '涨粉']]
            fig = px.bar(top20, x='涨粉', y='主播昵称', orientation='h',
                         color='涨粉', color_continuous_scale='Greens')
            fig.update_layout(height=500, yaxis={'autorange': 'reversed'})
            st.plotly_chart(fig, use_container_width=True)

    # 开播时长分布
    st.subheader("开播有效时长分布（分钟）")
